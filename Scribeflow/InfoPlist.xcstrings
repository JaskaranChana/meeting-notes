    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scribeflow can attach your notes to calendar meetings and pre-fill titles so each capture is linked to the right event."
          }
        }
      }
    },
    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scribeflow uses Face ID to unlock your secure session."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scribeflow uses the microphone to record meetings and voice notes you choose to capture. Audio stays on this device unless you explicitly enable a configured service or export it."
          }
        }
      }
    },
    "NSRemindersFullAccessUsageDescription" : {
      "comment" : "Privacy - Reminders Full Access Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scribeflow adds action items to Apple Reminders only when you choose to save them."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scribeflow uses Apple Speech to turn recordings into searchable transcripts on this device."
          }
        }
      }
    }
  },
  "version" : "1.0"
